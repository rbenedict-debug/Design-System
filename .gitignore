# Claude Code machine-specific settings (not project instructions)
.claude/settings.local.json
.claude/todos/

# Node
node_modules/
*.tgz

# ng-packagr regenerates these on every build but the root package.json /
# README.md are the canonical ones — these duplicates would only ship to
# consumers if accidentally committed. dist/.npmignore excludes them from
# the published tarball; this entry keeps them out of git too.
dist/README.md
dist/package.json

# macOS
.DS_Store
.DS_Store?
**/.DS_Store

# Editor
.vscode/
.idea/
*.swp
*.swo

# Environment / secrets — never commit these
.env
.env.*
*.pem
*.key
*.p12
*.pfx
*.cert

# Logs
*.log
npm-debug.log*

# OS
Thumbs.db
