{
  "name": "@onflo/design-system",
  "version": "0.2.0",
  "description": "Onflo Design System — tokens, components, and patterns for Angular + .NET Core products",
  "main": "./dist/fesm2022/onflo-design-system.mjs",
  "exports": {
    ".": {
      "types": "./dist/types/onflo-design-system.d.ts",
      "esm2022": "./dist/fesm2022/onflo-design-system.mjs",
      "default": "./dist/fesm2022/onflo-design-system.mjs"
    },
    "./dist/onflo.css": "./dist/onflo.css",
    "./dist/components.css": "./dist/components.css",
    "./dist/layout.css": "./dist/layout.css",
    "./tokens/css/index.css": "./tokens/css/index.css",
    "./tokens/css/design-tokens.css": "./tokens/css/design-tokens.css",
    "./tokens/scss/variables": "./tokens/scss/_variables.scss",
    "./tokens/scss/mixins": "./tokens/scss/_mixins.scss",
    "./tokens/scss/breakpoints": "./tokens/scss/_breakpoints.scss",
    "./package.json": {
      "default": "./package.json"
    }
  },
  "files": [
    "dist/",
    "tokens/",
    "AGENT-GUIDE.md",
    "preview/index.html",
    ".claude/specs/"
  ],
  "peerDependencies": {
    "@angular/animations": ">=21.0.0",
    "@angular/cdk": ">=21.0.0",
    "@angular/common": ">=21.0.0",
    "@angular/core": ">=21.0.0",
    "@angular/forms": ">=21.0.0",
    "@angular/material": ">=21.0.0",
    "ag-grid-community": ">=33.0.0",
    "highcharts": ">=11.0.0"
  },
  "scripts": {
    "generate-tokens": "node scripts/generate-tokens.js",
    "build-preview": "node scripts/build-preview.js",
    "build": "ng-packagr -p ng-package.json && sass components/index.scss dist/components.css --load-path=components --style=compressed --no-source-map && sass layout/index.scss dist/layout.css --style=compressed --no-source-map && node scripts/build-bundle.js",
    "preview": "open preview/index.html"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@angular/animations": "^21.2.7",
    "@angular/cdk": "^21.2.5",
    "@angular/common": "^21.2.7",
    "@angular/compiler": "^21.2.7",
    "@angular/compiler-cli": "^21.2.7",
    "@angular/core": "^21.2.7",
    "@angular/forms": "^21.2.7",
    "@angular/material": "^21.2.5",
    "ag-grid-community": "^35.2.1",
    "highcharts": "^11.4.8",
    "ng-packagr": "^21.2.2",
    "sass": "^1.98.0",
    "typescript": "~5.9.0"
  }
}
